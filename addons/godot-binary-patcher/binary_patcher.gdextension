[configuration]

entry_symbol = "godot_binary_patcher_library_init"
compatibility_minimum = "4.1"

[libraries]

macos.universal = "res://addons/godot-binary-patcher/bin/libgodot_binary_patcher.dylib"
windows.x86_64 = "res://addons/godot-binary-patcher/bin/libgodot_binary_patcher.dll"
linux.x86_64 = "res://addons/godot-binary-patcher/bin/libgodot_binary_patcher.so"